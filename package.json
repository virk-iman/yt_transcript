{
  "name": "yt_transcript_master",
  "version": "1.0.0",
  "scripts": {
    "start": "concurrently \"npm run backend-prod\" \"npm run worker-prod\"",
    "backend-prod": "cd backend && node index.js",
    "worker-prod": "cd backend && node summarizeWorker.js",
    "postinstall": "cd backend && npm install",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend/yt_transcript && npm run dev",
    "worker": "cd backend && npm run worker",
    "redis": "brew services start redis",
    "app": "npm run redis && concurrently \"npm run backend\" \"npm run frontend\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}